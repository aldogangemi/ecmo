cqs:CQ-CONS-N01 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ;
    cqs:targetsModule <http://data.europa.eu/h8v/ecmo/shapes> ;
    cqs:hasNLText "Do any ECMO classes inherit both dul:Description and dul:Situation?" ;
    cqs:exercisesPattern "Family I — ancestor-disjointness leak (D&S)" ;
    cqs:testKind "shacl" ;
    cqs:expectedAnswer "violation" ;
    cpa:hasUnitTest "# See :DescriptionVsSituationAncestorShape" .

cqs:CQ-CONS-N02 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ;
    cqs:targetsModule <http://data.europa.eu/h8v/ecmo/shapes> ;
    cqs:hasNLText "Do any ECMO classes inherit both dul:Object and dul:Quality (Capacity-ambiguity family)?" ;
    cqs:exercisesPattern "Family I — Object/Quality" ;
    cqs:testKind "shacl" ;
    cqs:expectedAnswer "violation" ;
    cpa:hasUnitTest "# See :ObjectVsQualityAncestorShape" .

cqs:CQ-CONS-N03 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ;
    cqs:targetsModule <http://data.europa.eu/h8v/ecmo/shapes> ;
    cqs:hasNLText "Is any resource asserted dul:Object AND object of a property with Quality range (EU_DRR_Capacity + evaluatesCopingCapacity family)?" ;
    cqs:exercisesPattern "Family II — property-range-induced O/Q" ;
    cqs:testKind "shacl" ;
    cqs:expectedAnswer "violation" ;
    cpa:hasUnitTest "# See :RangeInducedObjectVsQualityShape" .

cqs:CQ-CONS-N04 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ;
    cqs:targetsModule <http://data.europa.eu/h8v/ecmo/shapes> ;
    cqs:hasNLText "Is any resource typed dul:Description AND object of a property with Situation range (or the mirror)?" ;
    cqs:exercisesPattern "Family II — D/S leak via property range" ;
    cqs:testKind "shacl" ;
    cqs:expectedAnswer "violation" ;
    cpa:hasUnitTest "# See :RangeInducedDescriptionVsSituationShape" .

cqs:CQ-CONS-N05 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ;
    cqs:targetsModule <http://data.europa.eu/h8v/ecmo/shapes> ;
    cqs:hasNLText "Does any class carry a fschema:hasUnaryType annotation whose SemanticRole's ontoType it does not inherit?" ;
    cqs:exercisesPattern "Family III — Framester ontoType coherence" ;
    cqs:testKind "shacl" ;
    cqs:expectedAnswer "violation" ;
    cpa:hasUnitTest "# See :FramesterOntoTypeCoherenceShape" .

cqs:CQ-CONS-N06 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ;
    cqs:targetsModule <http://data.europa.eu/h8v/ecmo/shapes> ;
    cqs:hasNLText "Does any class play roles in two frames whose ontoTypes are disjoint, without a mediating fschema:hasPerspective (projection collapse)?" ;
    cqs:exercisesPattern "Family III — cross-frame projection collapse (Framester perspective shifts)" ;
    cqs:testKind "shacl" ;
    cqs:expectedAnswer "violation" ;
    cpa:hasUnitTest "# See :FramesterCrossFrameProjectionShape" .

cqs:CQ-CONS-N07 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ;
    cqs:targetsModule <http://data.europa.eu/h8v/ecmo/shapes> ;
    cqs:hasNLText "Does any fschema:CompositionalFrame declare component frames whose ontoTypes are pairwise disjoint (composition incoherent)?" ;
    cqs:exercisesPattern "Family III — compositional-frame coherence" ;
    cqs:testKind "shacl" ;
    cqs:expectedAnswer "violation" ;
    cpa:hasUnitTest "# See :FramesterCompositionalFrameCoherenceShape" .

# =============================================================================
# Load order (unchanged from v0.1)
#
#  - Load DUL.owl and d0.owl (for the disjointness axioms).
#  - Load framester.owl (for fschema:* vocabulary).
#  - Load the ECMO modules.
#  - Load the frame-model TTL (frames + SemanticRoles as fschema individuals,
#    class annotations via fschema:playsRoleIn / hasUnaryType). This file
#    lands when the frame model in ecmo-frame-structure-v0.2.md is validated.
#  - Load ecmo-property-alignments.ttl (the rdfs:subPropertyOf ledger).
#  - Then run the judge or pyshacl to fire the shapes.
# =============================================================================


# =============================================================================
# v2.3 task (d) — additional consistency shapes
# =============================================================================

# CP-IMP-02: every impact:Impact must carry at least one hasImpactIntensity triple.
:ImpactMustHaveIntensityShape a sh:NodeShape ;
    sh:targetClass impact:Impact ;
    sh:message "impact:Impact instance lacks a hasImpactIntensity triple — every Impact must be intensity-observable."@en ;
    sh:property [ sh:path impact:hasImpactIntensity ; sh:minCount 1 ] .

# CP-HAZ-02: scope-exclusion — flag any hazard:Hazard instance whose label suggests
# armed conflict / war / political tension (which the foundation:scopeExclusion excludes).
:HazardScopeExclusionShape a sh:NodeShape ;
    sh:targetClass hazard:Hazard ;
    sh:message "hazard:Hazard instance whose label matches conflict/war/tension terms — foundation:scopeExclusion applies."@en ;
    sh:sparql [ a sh:SPARQLConstraint ;
        sh:select """
            PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
            SELECT $this WHERE {
              $this rdfs:label ?l .
              FILTER (REGEX(STR(?l), "armed conflict|war|political tension|social instability", "i"))
            }""" ] .

# CP-PH-03: PathogenCharacteristic instances must have an associated Pathogen.
:PathogenCharacteristicOrphanShape a sh:NodeShape ;
    sh:targetClass ph:PathogenCharacteristic ;
    sh:message "ph:PathogenCharacteristic instance lacks an associated Pathogen — orphan characteristic."@en ;
    sh:sparql [ a sh:SPARQLConstraint ;
        sh:select """
            PREFIX ph: <http://data.europa.eu/h8v/ecmo/public-health/>
            SELECT $this WHERE {
              FILTER NOT EXISTS {
                { ?p ph:hasCaseFatalityRate $this }
                UNION { ?p ph:hasIncubationPeriod $this }
                UNION { ?p ph:hasInfectiousness $this }
                UNION { ?p ph:hasToxicity $this }
                UNION { ?p ph:hasTransmissibility $this }
              }
            }""" ] .

# CP-FND-02: every foundation:QualitativeAssessmentLevelScale must have unique orderInScale values.
:ScaleValueUniquenessShape a sh:NodeShape ;
    sh:targetClass foundation:QualitativeAssessmentLevelScale ;
    sh:message "Scale has two QualitativeAssessmentLevelValue instances sharing the same orderInScale — values must be unique per scale."@en ;
    sh:sparql [ a sh:SPARQLConstraint ;
        sh:select """
            PREFIX foundation: <http://data.europa.eu/h8v/ecmo/core/foundation/>
            SELECT $this ?v1 ?v2 ?order WHERE {
              ?v1 foundation:inScale $this ; foundation:orderInScale ?order .
              ?v2 foundation:inScale $this ; foundation:orderInScale ?order .
              FILTER (STR(?v1) < STR(?v2))
            }""" ] .

# CQ registrations (Q- CQs referencing the shapes above)
cqs:CQ-CONS-N08 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ; cqs:testKind "shacl" ; cqs:expectedAnswer "violation" ;
    cqs:hasNLText "Does any impact:Impact instance lack a hasImpactIntensity triple?" ;
    cpa:hasUnitTest "# See :ImpactMustHaveIntensityShape" .

cqs:CQ-CONS-N09 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ; cqs:testKind "shacl" ; cqs:expectedAnswer "violation" ;
    cqs:hasNLText "Does any hazard:Hazard instance carry a label matching the Sendai scope-exclusion terms?" ;
    cpa:hasUnitTest "# See :HazardScopeExclusionShape" .

cqs:CQ-CONS-N10 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ; cqs:testKind "shacl" ; cqs:expectedAnswer "violation" ;
    cqs:hasNLText "Does any ph:PathogenCharacteristic instance lack an associated pathogen (orphan)?" ;
    cpa:hasUnitTest "# See :PathogenCharacteristicOrphanShape" .

cqs:CQ-CONS-N11 a cqs:NegativeCompetencyQuestion ;
    cqs:hasPolarity "negative" ; cqs:testKind "shacl" ; cqs:expectedAnswer "violation" ;
    cqs:hasNLText "Does any scale have two QualitativeAssessmentLevelValue instances sharing an orderInScale?" ;
    cpa:hasUnitTest "# See :ScaleValueUniquenessShape" .
