ecmocore:hazard a owl:Ontology ;
    dcterms:issued "2026-03-22"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "Hazard typology (Natural, Anthropogenic, Socionatural, Biological, Geological, Hydrometeorological, Environmental, Technological), HazardousEvent and event subtypes, MultiHazardContext, and observation/pathogen-characteristic infrastructure."@en ;
    owl:imports ecmocore:foundation ;
    owl:versionInfo "2.2" ;
    skos:prefLabel "ECMO-CORE Hazard Module (F2)"@en .

hazard:AdvancedPersistentThreat a hazard:TechnologicalHazard,
        owl:NamedIndividual ;
    spec:specializes hazard:TechnologicalHazard ;
    owl:sameAs <https://www.undrr.org/terms/hips/tl0103> ;
    skos:prefLabel "Advanced Persistent Threat"@en .

hazard:AirTransportationAccident a hazard:TechnologicalHazard,
        owl:NamedIndividual ;
    spec:specializes hazard:TechnologicalHazard ;
    owl:sameAs <https://www.undrr.org/terms/hips/tl0401> ;
    skos:prefLabel "Air Transportation Accident"@en .

hazard:AnthropogenicEvent a owl:Class ;
    rdfs:comment "Hazards induced entirely or predominantly by human activities and choices."@en ;
    rdfs:subClassOf hazard:HazardousEvent ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:onProperty hazard:isManifestationOf ;
            owl:someValuesFrom hazard:AnthropogenicHazard ] ;
    skos:prefLabel "Anthropogenes Ereignis"@de,
        "Anthropogenic Event"@en,
        "Evento antropogénico"@es,
        "Événement anthropique"@fr,
        "Evento antropogenico"@it,
        "Evento antropogénico"@pt .

hazard:Avalanche a hazard:HydrometeorologicalHazard,
        owl:NamedIndividual ;
    spec:specializes hazard:HydrometeorologicalHazard ;
    owl:sameAs <https://www.undrr.org/terms/hips/mh0801> ;
    skos:prefLabel "Avalanche"@en .

hazard:BiologicalEvent a owl:Class ;
    rdfs:comment "Hazards of organic origin or conveyed by biological vectors, including pathogenic microorganisms, toxins and bioactive substances."@en ;
    rdfs:subClassOf hazard:HazardousEvent ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:onProperty hazard:isManifestationOf ;
            owl:someValuesFrom hazard:BiologicalHazard ] ;
    skos:prefLabel "Biologisches Ereignis"@de,
        "Biological Event"@en,
        "Evento biológico"@es,
        "Événement biologique"@fr,
        "Evento biologico"@it,
        "Evento biológico"@pt .

