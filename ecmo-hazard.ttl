    rdfs:subClassOf hazard:HazardousEvent ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:onProperty hazard:isManifestationOf ;
            owl:someValuesFrom hazard:RadiologicalHazard ] ;
    skos:prefLabel "Radiologisches Ereignis"@de,
        "Radiological Event"@en,
        "Evento radiológico"@es,
        "Événement radiologique"@fr,
        "Evento radiologico"@it,
        "Evento radiológico"@pt .

