hazard:TechnologicalEvent a owl:Class ;
    rdfs:comment "Hazards originating from technological or industrial conditions, dangerous procedures, infrastructure failures or specific human activities. Examples include industrial pollution, nuclear radiation, toxic wastes, dam failures, transport accidents, factory explosions, fires and chemical spills."@en ;
    rdfs:subClassOf hazard:HazardousEvent ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:onProperty hazard:isManifestationOf ;
            owl:someValuesFrom hazard:TechnologicalHazard ] ;
    skos:prefLabel "Technologisches Ereignis"@de,
        "Technological Event"@en,
        "Evento tecnológico"@es,
        "Événement technologique"@fr,
        "Evento tecnologico"@it,
        "Evento tecnológico"@pt .

