# =============================================================================
# ECMO consistency shapes — v0.2, Framester-native
#
# Change vs v0.1: Family III replaced. Instead of coref:hasFrameRole +
# roles:expectsAncestor (my ad-hoc vocab), the shapes use Framester natively:
#
#  - fschema:playsRoleIn      (class → Frame)
#  - fschema:hasUnaryType     (class → SemanticRole, the unary projection)
#  - fschema:ontoType         (SemanticRole → OntologyClass, the DOLCE ancestor)
#  - fschema:hasPerspective   (SemanticRole → Frame, perspective shift)
#
# Family I and Family II unchanged from v0.1 — they don't touch the frame
# vocabulary.
# =============================================================================

<http://data.europa.eu/h8v/ecmo/shapes> a owl:Ontology ;
    dcterms:issued "2026-06-08"^^xsd:date ;
    rdfs:comment "ECMO consistency shapes v0.2: DARKSIDE negative trail, Framester-native for Family III."@en ;
    owl:imports <http://data.europa.eu/h8v/ecmo/core> ,
                <http://data.europa.eu/h8v/ecmo/coref> ,
                <http://data.europa.eu/h8v/ecmo/property-alignments> ;
    owl:versionInfo "0.2" ;
    skos:prefLabel "ECMO Consistency Shapes (DARKSIDE, Framester-native)"@en .

# -----------------------------------------------------------------------------
# Family I — Ancestor-disjointness leaks (class-level). Unchanged from v0.1.
# -----------------------------------------------------------------------------

:DescriptionVsSituationAncestorShape a sh:NodeShape ;
    sh:targetClass owl:Class ;
    sh:message "Class inherits both dul:Description and dul:Situation — D&S boundary violation."@en ;
    sh:sparql [ a sh:SPARQLConstraint ;
        sh:select """
            PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
            PREFIX dul:  <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#>
            SELECT $this WHERE {
              $this rdfs:subClassOf* dul:Description .
              $this rdfs:subClassOf* dul:Situation .
              FILTER($this != dul:Description && $this != dul:Situation)
            }""" ] .

:EventVsObjectAncestorShape a sh:NodeShape ;
    sh:targetClass owl:Class ;
    sh:message "Class inherits both dul:Event and dul:Object — DUL disjointness violation."@en ;
    sh:sparql [ a sh:SPARQLConstraint ; sh:select """
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        PREFIX dul:  <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#>
        SELECT $this WHERE {
          $this rdfs:subClassOf* dul:Event . $this rdfs:subClassOf* dul:Object .
          FILTER($this != dul:Event && $this != dul:Object)
        }""" ] .

:EventVsQualityAncestorShape a sh:NodeShape ;
    sh:targetClass owl:Class ;
    sh:message "Class inherits both dul:Event and dul:Quality — DUL disjointness violation."@en ;
    sh:sparql [ a sh:SPARQLConstraint ; sh:select """
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        PREFIX dul:  <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#>
        SELECT $this WHERE {
          $this rdfs:subClassOf* dul:Event . $this rdfs:subClassOf* dul:Quality .
          FILTER($this != dul:Event && $this != dul:Quality)
        }""" ] .

:ObjectVsQualityAncestorShape a sh:NodeShape ;
    sh:targetClass owl:Class ;
    sh:message "Class inherits both dul:Object and dul:Quality — Capacity ambiguity family."@en ;
    sh:sparql [ a sh:SPARQLConstraint ; sh:select """
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        PREFIX dul:  <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#>
        SELECT $this WHERE {
          $this rdfs:subClassOf* dul:Object . $this rdfs:subClassOf* dul:Quality .
          FILTER($this != dul:Object && $this != dul:Quality)
        }""" ] .

:ConceptVsSituationAncestorShape a sh:NodeShape ;
    sh:targetClass owl:Class ;
    sh:message "Class inherits both dul:Concept and dul:Situation — DUL disjointness violation."@en ;
    sh:sparql [ a sh:SPARQLConstraint ; sh:select """
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        PREFIX dul:  <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#>
        SELECT $this WHERE {
          $this rdfs:subClassOf* dul:Concept . $this rdfs:subClassOf* dul:Situation .
          FILTER($this != dul:Concept && $this != dul:Situation)
        }""" ] .

:DescriptionVsInformationObjectAncestorShape a sh:NodeShape ;
    sh:targetClass owl:Class ;
    sh:message "Class inherits both dul:Description and dul:InformationObject — DUL disjointness violation."@en ;
    sh:sparql [ a sh:SPARQLConstraint ; sh:select """
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        PREFIX dul:  <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#>
        SELECT $this WHERE {
          $this rdfs:subClassOf* dul:Description . $this rdfs:subClassOf* dul:InformationObject .
          FILTER($this != dul:Description && $this != dul:InformationObject)
        }""" ] .

# -----------------------------------------------------------------------------
# Family II — Property-range-induced disjointness. Unchanged from v0.1.
# -----------------------------------------------------------------------------

:RangeInducedObjectVsQualityShape a sh:NodeShape ;
    sh:targetClass owl:Thing ;
    sh:message "Resource asserted dul:Object AND object of a property with range ⊆ dul:Quality (or mirror). Capacity-ambiguity family."@en ;
    sh:sparql [ a sh:SPARQLConstraint ; sh:select """
        PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        PREFIX dul:  <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#>
        SELECT $this ?p ?R WHERE {
          { $this a ?T . ?T rdfs:subClassOf* dul:Object .
            ?s ?p $this . ?p rdfs:range ?R . ?R rdfs:subClassOf* dul:Quality . }
          UNION
          { $this a ?T . ?T rdfs:subClassOf* dul:Quality .
            ?s ?p $this . ?p rdfs:range ?R . ?R rdfs:subClassOf* dul:Object . }
        }""" ] .

:RangeInducedEventVsObjectShape a sh:NodeShape ;
    sh:targetClass owl:Thing ;
    sh:message "Resource typed dul:Event AND object of a property with range ⊆ dul:Object (or mirror)."@en ;
    sh:sparql [ a sh:SPARQLConstraint ; sh:select """
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        PREFIX dul:  <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#>
        SELECT $this ?p ?R WHERE {
          { $this a ?T . ?T rdfs:subClassOf* dul:Event .
            ?s ?p $this . ?p rdfs:range ?R . ?R rdfs:subClassOf* dul:Object . }
          UNION
          { $this a ?T . ?T rdfs:subClassOf* dul:Object .
            ?s ?p $this . ?p rdfs:range ?R . ?R rdfs:subClassOf* dul:Event . }
        }""" ] .

:RangeInducedDescriptionVsSituationShape a sh:NodeShape ;
    sh:targetClass owl:Thing ;
    sh:message "Resource typed dul:Description AND object of a property with range ⊆ dul:Situation (or mirror) — D&S boundary leak."@en ;
    sh:sparql [ a sh:SPARQLConstraint ; sh:select """
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        PREFIX dul:  <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#>
        SELECT $this ?p ?R WHERE {
          { $this a ?T . ?T rdfs:subClassOf* dul:Description .
            ?s ?p $this . ?p rdfs:range ?R . ?R rdfs:subClassOf* dul:Situation . }
          UNION
          { $this a ?T . ?T rdfs:subClassOf* dul:Situation .
            ?s ?p $this . ?p rdfs:range ?R . ?R rdfs:subClassOf* dul:Description . }
        }""" ] .

# -----------------------------------------------------------------------------
# Family III — Frame-role coherence, Framester-native (REPLACES v0.1 shapes).
# The v0.1 versions used coref:hasFrameRole / roles:expectsAncestor. Those are
# retired. The new shapes read the frame model via Framester:
#
#   ?class fschema:playsRoleIn  ?frame .
#   ?class fschema:hasUnaryType ?role .        # role is a fschema:SemanticRole
#   ?role  fschema:ontoType     ?dolceClass .  # DOLCE ancestor the class must inherit
#   ?role  fschema:hasPerspective ?otherFrame . # perspective shift, optional
#
# When the frame model TTL (frames+roles as fschema:Frame/SemanticRole
# individuals) is loaded alongside ECMO, the shapes fire on any class whose
# hasUnaryType role's ontoType is not in the class's subClassOf* closure.
# -----------------------------------------------------------------------------

:FramesterOntoTypeCoherenceShape a sh:NodeShape ;
    sh:targetClass owl:Class ;
    sh:message "Class carries a fschema:hasUnaryType annotation whose SemanticRole's fschema:ontoType is not in the class's subClassOf* closure. Frame-role coherence violation."@en ;
    sh:sparql [ a sh:SPARQLConstraint ;
        sh:select """
            PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
            PREFIX fschema: <https://w3id.org/framester/schema/>
            SELECT $this ?role ?expected WHERE {
              $this fschema:hasUnaryType ?role .
              ?role fschema:ontoType ?expected .
              FILTER NOT EXISTS { $this rdfs:subClassOf* ?expected . }
            }""" ] .

:FramesterCrossFrameProjectionShape a sh:NodeShape ;
    sh:targetClass owl:Class ;
    sh:message "Class plays roles in two frames whose fschema:ontoType targets are disjoint, without a mediating fschema:hasPerspective — projection collapse detected."@en ;
    sh:sparql [ a sh:SPARQLConstraint ;
        sh:select """
            PREFIX fschema: <https://w3id.org/framester/schema/>
            PREFIX owl:     <http://www.w3.org/2002/07/owl#>
            SELECT $this ?role1 ?role2 ?anc1 ?anc2 WHERE {
              $this fschema:hasUnaryType ?role1, ?role2 .
              ?role1 fschema:ontoType ?anc1 . ?role2 fschema:ontoType ?anc2 .
              ?anc1 owl:disjointWith ?anc2 .
              FILTER (STR(?role1) < STR(?role2))
              # exclude legitimate perspective shifts
              FILTER NOT EXISTS { ?role1 fschema:hasPerspective ?fr . ?role2 fschema:semanticRoleOf ?fr . }
              FILTER NOT EXISTS { ?role2 fschema:hasPerspective ?fr . ?role1 fschema:semanticRoleOf ?fr . }
            }""" ] .

:FramesterCompositionalFrameCoherenceShape a sh:NodeShape ;
    sh:targetClass fschema:CompositionalFrame ;
    sh:message "CompositionalFrame declares intensionalComponent frames whose union of ontoTypes is empty at DOLCE level — the composition cannot be instantiated coherently."@en ;
    sh:sparql [ a sh:SPARQLConstraint ;
        sh:select """
            PREFIX fschema: <https://w3id.org/framester/schema/>
            PREFIX owl:     <http://www.w3.org/2002/07/owl#>
            SELECT $this ?f1 ?f2 ?anc1 ?anc2 WHERE {
              $this fschema:intensionalComponent ?f1, ?f2 .
              ?f1 fschema:semanticRole ?r1 . ?r1 fschema:ontoType ?anc1 .
              ?f2 fschema:semanticRole ?r2 . ?r2 fschema:ontoType ?anc2 .
              ?anc1 owl:disjointWith ?anc2 .
              FILTER (STR(?f1) < STR(?f2))
            }""" ] .

